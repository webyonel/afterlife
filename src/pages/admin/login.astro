---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout
  title="Panel de administración — After Life"
  description="Acceso restringido al panel de administración de After Life."
  noindex={true}
>
  <Navbar />

  <main class="login">
    <section class="card" aria-labelledby="login-title">
      <header class="head">
        <span class="eyebrow">Panel de administración</span>
        <h1 id="login-title" class="title">Bienvenido de vuelta</h1>
        <p class="lead">
          Inicia sesión para gestionar productos y todo tu menú.
        </p>
      </header>

      <form class="form" novalidate>
        <label class="field">
          <span class="label">Correo electrónico</span>
          <input
            type="email"
            name="email"
            placeholder="tu@correo.com"
            required
            autocomplete="email"
            data-login-email
          />
        </label>

        <label class="field">
          <span class="label">Contraseña</span>
          <input
            type="password"
            name="password"
            placeholder="••••••••"
            required
            minlength="6"
            autocomplete="current-password"
            data-login-password
          />
        </label>

        <button type="submit" class="submit" data-login-submit>
          Iniciar sesión
        </button>
      </form>
      <footer class="foot">
        <a href="/" class="back">← Volver al sitio</a>
      </footer>
    </section>
  </main>
</Layout>

<style>
  .login {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 16px 80px;
  }

  .card {
    width: 100%;
    max-width: 440px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: clamp(28px, 4vw, 40px) clamp(24px, 4vw, 32px);
    box-shadow: var(--shadow-nav);
  }

  .head {
    text-align: center;
    margin-bottom: 28px;
  }

  .eyebrow {
    display: inline-block;
    color: var(--color-brand);
    font-weight: 600;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 10px;
  }

  .title {
    font-size: clamp(24px, 3vw, 30px);
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }

  .lead {
    color: var(--color-text-muted);
    font-size: 14px;
    margin: 0;
    line-height: 1.5;
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-text);
  }

  .field input {
    border: 1px solid var(--color-border);
    background: var(--color-surface-soft);
    border-radius: var(--radius-pill);
    padding: 13px 18px;
    font-size: 15px;
    color: var(--color-text);
    font-family: inherit;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    outline: none;
    width: 100%;
  }

  .field input::placeholder {
    color: #aaa;
  }

  .field input:hover {
    border-color: #c8c8c8;
  }

  .field input:focus {
    border-color: var(--color-brand);
    background: var(--color-surface);
    box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.15);
  }

  .extras {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 13px;
    gap: 12px;
    flex-wrap: wrap;
  }

  .check {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text-muted);
    cursor: pointer;
    user-select: none;
  }

  .check input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--color-brand);
    cursor: pointer;
  }

  .link {
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .link:hover {
    color: var(--color-brand-dark);
    text-decoration: underline;
  }

  .submit {
    margin-top: 8px;
    background: var(--color-brand);
    color: #fff;
    font-weight: 600;
    font-size: 15px;
    border: none;
    border-radius: var(--radius-pill);
    padding: 14px 24px;
    transition: background 0.2s ease, transform 0.1s ease, opacity 0.2s ease;
    cursor: pointer;
  }

  .submit:hover {
    background: var(--color-brand-dark);
  }

  .submit:active {
    transform: scale(0.98);
  }

  .submit:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }

  .error {
    margin: 0;
    color: #c0392b;
    background: #fdecea;
    border-radius: 12px;
    padding: 10px 14px;
    font-size: 13px;
    text-align: center;
  }

  .foot {
    margin-top: 24px;
    text-align: center;
  }

  .back {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s ease;
  }

  .back:hover {
    color: var(--color-text);
  }
</style>

<script>
  import { supabase } from "../../lib/supabase";

  // Estrecha un resultado posiblemente-null de un querySelector y lanza un error
  // descriptivo si no se encontró. TypeScript NO propaga el narrowing a través de
  // closures (listeners, handlers), así que este helper asegura tipos no-null
  // estables para todo el resto del script.
  function requireEl<T>(value: T | null, message: string): T {
    if (value === null) throw new Error(message);
    return value;
  }

  // ---------- Referencias al DOM ----------
  const form = requireEl(
    document.querySelector<HTMLFormElement>(".form"),
    "No se encontró el formulario",
  );
  const emailInput = requireEl(
    form.querySelector<HTMLInputElement>("[data-login-email]"),
    "Falta el campo de correo electrónico",
  );
  const passwordInput = requireEl(
    form.querySelector<HTMLInputElement>("[data-login-password]"),
    "Falta el campo de contraseña",
  );
  const submitButton = requireEl(
    form.querySelector<HTMLButtonElement>("[data-login-submit]"),
    "Falta el botón de inicio de sesión",
  );

  // ---------- Constantes ----------
  const MIN_PASSWORD_LENGTH = 6;
  // Regex estilo HTML5 — suficiente para detectar entradas mal formadas sin reinventar la rueda
  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const ORIGINAL_BUTTON_TEXT = (submitButton.textContent ?? "Iniciar sesión").trim();

  // ---------- Banner de error (reusa la clase .error ya estilada arriba) ----------
  const errorBanner = document.createElement("p");
  errorBanner.className = "error";
  errorBanner.setAttribute("role", "alert");
  errorBanner.hidden = true;
  form.insertBefore(errorBanner, form.firstChild);

  function clearError(): void {
    errorBanner.hidden = true;
    errorBanner.textContent = "";
    emailInput.removeAttribute("aria-invalid");
    passwordInput.removeAttribute("aria-invalid");
  }

  function showError(message: string): void {
    errorBanner.textContent = message;
    errorBanner.hidden = false;
  }

  // ---------- Validación ----------
  function validate(): { email: string; password: string } | null {
    const email = emailInput.value.trim().toLowerCase();
    const password = passwordInput.value;

    if (!email) {
      showError("Ingresa tu correo electrónico.");
      emailInput.setAttribute("aria-invalid", "true");
      emailInput.focus();
      return null;
    }
    if (!EMAIL_RE.test(email)) {
      showError("El correo no tiene un formato válido.");
      emailInput.setAttribute("aria-invalid", "true");
      emailInput.focus();
      return null;
    }
    if (!password) {
      showError("Ingresa tu contraseña.");
      passwordInput.setAttribute("aria-invalid", "true");
      passwordInput.focus();
      return null;
    }
    if (password.length < MIN_PASSWORD_LENGTH) {
      showError(`La contraseña debe tener al menos ${MIN_PASSWORD_LENGTH} caracteres.`);
      passwordInput.setAttribute("aria-invalid", "true");
      passwordInput.focus();
      return null;
    }

    clearError();
    return { email, password };
  }

  function setLoading(loading: boolean): void {
    submitButton.disabled = loading;
    submitButton.textContent = loading ? "Iniciando…" : ORIGINAL_BUTTON_TEXT;
  }

  // ---------- Limpiar errores al editar ----------
  emailInput.addEventListener("input", clearError);
  passwordInput.addEventListener("input", clearError);

  // ---------- Submit ----------
  form.addEventListener("submit", async (event) => {
    event.preventDefault();

    const validated = validate();
    if (!validated) return;

    setLoading(true);

    const { error } = await supabase.auth.signInWithPassword({
      email: validated.email,
      password: validated.password,
    });

    setLoading(false);

    if (error) {
      // Mensaje genérico: NO revelar si el email existe, si la cuenta está confirmada, etc.
      showError("Credenciales inválidas.");
      passwordInput.focus();
      passwordInput.select();
      return;
    }

    // replace() para que el botón "atrás" no devuelva al usuario al login con sesión activa
    window.location.replace("/admin");
  });

  // ---------- Si ya hay sesión activa, saltar el login ----------
  void (async () => {
    const { data, error } = await supabase.auth.getSession();
    if (!error && data.session) {
      window.location.replace("/admin");
    }
  })();
</script>
