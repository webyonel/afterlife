---
// Shell vacío: las tabs las inyecta el script de la página que lo usa
// (categorías reales vienen de Supabase). El data-tabs es el hook para el
// render dinámico; el data-h-scroll mantiene el comportamiento de scroll
// horizontal con la rueda del ratón.
---

<div class="tabs-wrap">
  <div class="tabs" role="tablist" data-h-scroll data-tabs></div>
</div>

<style>
  .tabs-wrap {
    width: 100%;
    max-width: var(--container-grid);
    margin: clamp(32px, 5vw, 44px) auto 0;
    /* Padding lateral generoso para que la pastilla no quede pegada al
       borde de la pantalla. */
    padding: 0 32px;
  }

  .tabs {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--color-surface-soft);
    border-radius: var(--radius-pill);
    /* Padding generoso para que el marco gris alrededor del tab activo
       (especialmente por la izquierda) sea claramente visible y separe
       visualmente el primer tab del fondo. */
    padding: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    -ms-overflow-style: none;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }

  .tabs::-webkit-scrollbar {
    display: none;
  }

  /* Los botones .tab se inyectan desde el script del consumidor (index.astro),
     sin el scope-id de este componente. Usamos :global(.tab) para que las
     reglas apliquen a cualquier descendiente de .tabs, tengan o no el
     data-astro-cid-XXX. */
  .tabs :global(.tab) {
    border: none;
    background: transparent;
    color: var(--color-text-muted);
    font-size: clamp(14px, 1.2vw, 16px);
    font-weight: 500;
    padding: 10px 18px;
    border-radius: var(--radius-pill);
    transition: background-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .tabs :global(.tab) {
      padding: 10px 22px;
    }
  }

  .tabs :global(.tab:hover) {
    color: var(--color-text);
  }

  .tabs :global(.tab.active) {
    background: var(--color-brand);
    color: #fff;
  }
</style>

<script>
  // Convierte el wheel vertical en scroll horizontal cuando el contenedor
  // tiene más contenido del que cabe. Asi funciona con la rueda del ratón
  // en laptops, no solo con touchpad o pantallas táctiles.
  document.querySelectorAll<HTMLElement>("[data-h-scroll]").forEach((el) => {
    el.addEventListener(
      "wheel",
      (e) => {
        if (e.deltaY === 0) return;
        // Si el usuario ya está haciendo scroll horizontal (touchpad), respeta eso
        if (Math.abs(e.deltaX) > Math.abs(e.deltaY)) return;

        const max = el.scrollWidth - el.clientWidth;
        if (max <= 0) return;

        const atStart = el.scrollLeft <= 0 && e.deltaY < 0;
        const atEnd = el.scrollLeft >= max - 1 && e.deltaY > 0;
        // Deja que la página haga scroll vertical si estamos en el extremo
        if (atStart || atEnd) return;

        e.preventDefault();
        el.scrollLeft += e.deltaY;
      },
      { passive: false },
    );
  });
</script>
